# MongoDB (required) — do not commit real credentials
# Atlas: paste Drivers connection string; rotate password if it was ever exposed in chat/logs
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=hobbyhop

# Optional: Google Maps — set NEXT_PUBLIC_* for the Discover map and Places autocomplete (browser)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# /api/geocode may use GOOGLE_MAPS_API_KEY (server) or fall back to the NEXT_PUBLIC key
# GOOGLE_MAPS_API_KEY=

# App URL for server-side geocode fetch
# NEXT_PUBLIC_APP_URL=http://localhost:3000
